# Environment configuration — copy to .env and fill values
# ─────────────────────────────────────────────────────────

# Image search uses DuckDuckGo — no API key needed

# Paths
PROJECTS_DIR=./projects
WEIGHTS_DIR=./weights
FONTS_DIR=./fonts
LUTS_DIR=./luts

# FFmpeg
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Rendering defaults
DEFAULT_WIDTH=1080
DEFAULT_HEIGHT=1920
DEFAULT_FPS=30
DEFAULT_CRF=18
DEFAULT_PRESET=medium

# Database
DATABASE_URL=sqlite+aiosqlite:///./video_ai.db

# API
API_HOST=0.0.0.0
API_PORT=8000
